Grammar

    0 $accept: program_prime $end

    1 program_prime: program

    2 program: ACCIO stmt_list LUMOS

    3 block: BEGIN_BLK stmt_list END_BLK

    4 stmt_list: stmt_list stmt
    5          | ε

    6 stmt: var_decl DOLLAR
    7     | assignment DOLLAR
    8     | if_stmt
    9     | while_stmt
   10     | for_stmt
   11     | block
   12     | func_decl DOLLAR
   13     | func_call DOLLAR
   14     | break_stmt DOLLAR
   15     | continue_stmt DOLLAR
   16     | return_stmt DOLLAR

   17 var_decl: VARIABLE ID COLON type

   18 type: TYPE_INT
   19     | TYPE_LONG
   20     | TYPE_SHORT
   21     | TYPE_FLOAT
   22     | TYPE_DOUBLE
   23     | TYPE_CHAR
   24     | TYPE_VOID

   25 assignment: ID ASSIGN expr

   26 if_prefix: IF LPAREN condition RPAREN

   27 if_stmt: if_prefix block

   28 @1: ε

   29 if_stmt: if_prefix block ELSE @1 block

   30 @2: ε

   31 $@3: ε

   32 while_stmt: WHILE @2 LPAREN condition RPAREN $@3 block

   33 $@4: ε

   34 $@5: ε

   35 $@6: ε

   36 for_stmt: FOR LPAREN assignment DOLLAR $@4 condition DOLLAR $@5 assignment RPAREN $@6 block

   37 func_call: CALL ID LPAREN arg_list RPAREN

   38 arg_list: args
   39         | ε

   40 args: args COMMA expr
   41     | expr

   42 func_decl: FUNC type ID LPAREN param_list RPAREN block

   43 param_list: param_list COMMA param
   44           | param
   45           | ε

   46 param: ID COLON type

   47 return_stmt: RETURN expr

   48 break_stmt: BREAK

   49 continue_stmt: CONTINUE

   50 condition: expr rel_op expr
   51          | condition AND condition
   52          | condition OR condition
   53          | NOT condition
   54          | LPAREN condition RPAREN

   55 rel_op: LT
   56       | GT
   57       | EQ
   58       | LE
   59       | GE
   60       | NE

   61 expr: expr PLUS term
   62     | expr MINUS term
   63     | term

   64 term: term MULT factor
   65     | term DIV factor
   66     | term MOD factor
   67     | factor

   68 factor: LPAREN expr RPAREN
   69       | MINUS factor
   70       | ID
   71       | NUMBER


